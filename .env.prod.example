# ── Dominio e Traefik ────────────────────────────────────────────────────────
# Host principale del sito (senza https://)
APP_HOST=rifugiebivacchi.cailugo.it

# Host pgAdmin (solo se usi --profile tools)
PGADMIN_HOST=pgadmin-rifugiebivacchi.cailugo.it

# Basic-auth Traefik per pgAdmin (genera con: htpasswd -nB user)
# Ricorda di RADDOPPIARE i $ nel file .env.prod
# PGADMIN_BASIC_AUTH=admin:$$apr1$$...

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=rifugio
POSTGRES_USER=rifugio
POSTGRES_PASSWORD=CAMBIA_QUESTA_PASSWORD_DB

# ── Backend API ──────────────────────────────────────────────────────────────
JWT_SECRET=CAMBIA_QUESTO_JWT_SECRET_LUNGO_E_CASUALE

# Admin di emergenza (creato al primo avvio se auth_users.csv assente)
# ADMIN_EMAIL=assistenza@goodkarma.it
# ADMIN_PASSWORD=

# Email notifiche nuovi annunci (relay SMTP senza autenticazione)
SMTP_HOST=relay.evoluzioniweb.it
SMTP_PORT=25
SMTP_FROM=Rifugi e Bivacchi <noreply@cailugo.it>
SMTP_ENVELOPE_FROM=noreply@cailugo.it
ADMIN_NOTIFY_EMAIL=rifugi@cailugo.it
ADMIN_NOTIFY_BCC=assistenza@goodkarma.it

# ── pgAdmin (profilo tools) ──────────────────────────────────────────────────
PGADMIN_EMAIL=assistenza@goodkarma.it
PGADMIN_PASSWORD=Goodkarma2026!
